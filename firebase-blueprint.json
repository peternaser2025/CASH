{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "employee": { "type": "string" },
        "branch": { "type": "string" },
        "type": { 
          "type": "string", 
          "enum": ["Income", "Expense", "Transfer-In", "Transfer-Out", "Accrual-Receivable", "Accrual-Payable"] 
        },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "relatedId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "employee", "branch", "type", "amount"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Employee record with balance",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of all financial transactions"
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of employee records"
    }
  }
}
